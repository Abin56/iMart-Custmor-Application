<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for Razorpay test mode -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Razorpay domains -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">razorpay.com</domain>
        <domain includeSubdomains="true">api.razorpay.com</domain>
        <domain includeSubdomains="true">lumberjack.razorpay.com</domain>
    </domain-config>
</network-security-config>
